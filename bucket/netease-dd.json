            "url": "https://cc.gdl.netease.com/NetEase_DD_Setup_100113_312864_x64.exe?key1=7dadeb0a4f1d8274ea1b04967d4a79d2&key2=69f2f21f#/dl.7z"
        }
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "$matchUrl64#/dl.7z"
            }
        }
    },
    "checkver": {
        "script": [
            "$script:ver = json_path $page '$.data.version' -single $true",
            "$script:matchesHashtable = @{",
            "   'url64' = (json_path $page '$.data.downloadUrlFor64' -single $true)",
            "}",
            "$script:regexp = $null"
        ],
        "url": "https://appapi.cc.163.com/v1/mixteamversion/getDownloadUrl"
    },
    "description": "网易DD，原有爱插件。",
    "homepage": "https://dd.163.com",
    "license": {
        "identifier": "Freeware",
        "url": "https://dd.163.com/policy/privacy"
    },
    "pre_install": [
        "$targetPath = \"$env:LocalAppData\\NeteaseDD\"",
        "if (Test-Path \"$targetPath\") {",
        "    Remove-Item -Path \"$targetPath\" -Force -Recurse",
        "}",
        "New-Item \"$targetPath\" -ItemType Junction -Target \"$dir\" | Out-Null"
    ],
    "post_install": [
        "Remove-Item \"$dir\\`$*\" -Recurse -Force -ErrorAction SilentlyContinue",
        "ensure \"$persist_dir\" | Out-Null",
        "$targetPath = \"$env:AppData\\CCVoiceHub\"",
        "$linkType = (Get-Item -Path \"$targetPath\" -ErrorAction SilentlyContinue).LinkType",
        "if (Test-Path \"$targetPath\") {",
        "    if ($linkType -eq 'Junction') {",
        "        Remove-Item -Path \"$targetPath\" -Force",
        "    } else {",
        "        Get-ChildItem -Path \"$targetPath\" -Force | Move-Item -Destination $persist_dir -Force",
        "        Remove-Item -Path \"$targetPath\" -Force -Recurse",
        "    }",
        "}",
        "New-Item \"$targetPath\" -ItemType Junction -Target \"$persist_dir\" | Out-Null"
    ],
    "uninstaller": {
        "script": [
            "Remove-Item -Path \"$env:LocalAppData\\NeteaseDD\" -Force -Recurse -ErrorAction SilentlyContinue",
            "Remove-Item -Path \"$env:AppData\\CCVoiceHub\" -Force -Recurse -ErrorAction SilentlyContinue"
        ]
    },
    "shortcuts": [
        [
            "Start.exe",
            "网易DD"
        ]
    ],
    "version": "1.1.13"
}
