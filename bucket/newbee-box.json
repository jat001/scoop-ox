{
    "description": "新手盒子是一款管理魔兽世界插件及实时伤害排行榜的桌面客户端。",
    "extract_dir": "$PLUGINSDIR",
    "hash": "a66cbae5b5e1aea8d7b850801b529490bae230aefcdcaceec76df4c9c36afa5e",
    "homepage": "https://www.wclbox.com",
    "installer": {
        "script": [
            "Remove-Item \"$dir\\*\" -Exclude 'app-64.7z'",
            "Expand-7zipArchive \"$dir\\app-64.7z\" \"$dir\" -Removal"
        ]
    },
    "license": {
        "identifier": "Freeware"
    },
    "shortcuts": [
        [
            "NewBeeBox.exe",
            "新手盒子"
        ]
    ],
    "url": "https://cdn8.newbeebox.com/installer/NewBeeBox%20Setup%201.1.0.exe#/dl.7z",
    "version": "1.1.0",
    "checkver": {
        "regex": "NewBeeBox%20Setup%20([\\d.]+)\\.exe"
    },
    "autoupdate": {
        "url": "https://cdn8.newbeebox.com/installer/NewBeeBox%20Setup%20$version.exe#/dl.7z"
    },
    "post_install": [
        "ensure \"$persist_dir\" | Out-Null",
        "$targetPath = \"$env:AppData\\NewBeeBox\"",
        "$linkType = (Get-Item -Path \"$targetPath\" -ErrorAction SilentlyContinue).LinkType",
        "if (Test-Path \"$targetPath\") {",
        "    if ($linkType -eq 'Junction') {",
        "        Remove-Item -Path \"$targetPath\" -Force",
        "    } else {",
        "        Get-ChildItem -Path \"$targetPath\" -Force | Move-Item -Destination $persist_dir -Force",
        "        Remove-Item -Path \"$targetPath\" -Force -Recurse",
        "    }",
        "}",
        "New-Item \"$targetPath\" -ItemType Junction -Target \"$persist_dir\" | Out-Null"
    ],
    "uninstaller": {
        "script": "Remove-Item -Path \"$env:AppData\\NewBeeBox\" -Force -Recurse -ErrorAction SilentlyContinue"
    }
}
