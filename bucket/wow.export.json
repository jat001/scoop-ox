{
    "version": "0.2.14",
    "description": "Export toolkit for World of Warcraft.",
    "homepage": "https://www.kruithne.net/wow.export",
    "license": {
        "identifier": "MIT",
        "url": "https://github.com/Kruithne/wow.export/blob/main/LICENSE"
    },
    "url": "https://github.com/Kruithne/wow.export/releases/download/0.2.14/portable-wow-export-win-x64-0.2.14.zip",
    "hash": "d3f17c675be2c9a2c4e2f5af772dbe1373b1e66024d5d223ad9179e9de73a232",
    "post_install": [
        "ensure \"$persist_dir\" | Out-Null",
        "$targetPath = \"$env:LocalAppData\\wow.export\"",
        "$linkType = (Get-Item -Path \"$targetPath\" -ErrorAction SilentlyContinue).LinkType",
        "if (Test-Path \"$targetPath\") {",
        "    if ($linkType -eq 'Junction') {",
        "        Remove-Item -Path \"$targetPath\" -Force",
        "    } else {",
        "        Get-ChildItem -Path \"$targetPath\" -Force | Move-Item -Destination $persist_dir -Force",
        "        Remove-Item -Path \"$targetPath\" -Force -Recurse",
        "    }",
        "}",
        "New-Item \"$targetPath\" -ItemType Junction -Target \"$persist_dir\" | Out-Null"
    ],
    "uninstaller": {
        "script": "Remove-Item -Path \"$env:LocalAppData\\wow.export\" -Force -Recurse -ErrorAction SilentlyContinue"
    },
    "shortcuts": [
        [
            "wow.export.exe",
            "wow.export"
        ]
    ],
    "checkver": {
        "github": "https://github.com/Kruithne/wow.export"
    },
    "autoupdate": {
        "url": "https://github.com/Kruithne/wow.export/releases/download/$version/portable-wow-export-win-x64-$version.zip"
    }
}
